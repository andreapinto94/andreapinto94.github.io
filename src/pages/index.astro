---
import scholarData from '../data/scholar.json';
import '../styles/global.css';

// Sort papers by citations descending first, then by year
const sortedPapers = scholarData.publications.sort((a, b) => {
  if (b.citations !== a.citations) {
    return (b.citations || 0) - (a.citations || 0);
  }
  const yearA = parseInt(a.year) || 0;
  const yearB = parseInt(b.year) || 0;
  return yearB - yearA;
});

const getVenue = (title) => {
  const t = title.toLowerCase();
  if (t.includes("plebiscito")) return "IFIP Networking";
  if (t.includes("federated split learning")) return "IEEE Transactions on Big Data (TBD)";
  if (t.includes("characterizing location management")) return "IEEE NFV-SDN";
  if (t.includes("hercules:")) return "ACM WiNTECH";
  if (t.includes("experimenting with localization")) return "ACM MobiCom";
  if (t.includes("lossy wireless networks")) return "IEEE CNSM";
  if (t.includes("transport-aware resource block") || t.includes("transport-aware")) return "IEEE NetSoft";
  if (t.includes("balancing energy efficiency")) return "ACM MECC";
  if (t.includes("optimizing model pruning") || t.includes("dfl-trim")) return "IEEE NetSoft";
  if (t.includes("mitigating de-authentication")) return "IEEE NetSoft";
  if (t.includes("optical-wireless networks")) return "IEEE ICTON";
  if (t.includes("maestro:")) return "MIDL";
  if (t.includes("trireme:")) return "ICS";
  if (t.includes("rubix:")) return "IPDPS";
  if (t.includes("flllm:")) return "Under Submission";
  return "";
};

const getAuthors = (title) => {
  const t = title.toLowerCase();
  if (t.includes("plebiscito")) return "A. Pinto, S. Galantino, F. Risso, & F. Esposito";
  if (t.includes("federated split learning")) return "Z. Zhang, A. Pinto, V. Turina, F. Esposito & I. Matta";
  if (t.includes("hercules")) return "A. Pinto, A. Ashdown, T. Bin Hassan, H. Cheng, F. Esposito, L. Bonati, S. D'Oro, T. Melodia, & F. Restuccia";
  if (t.includes("balancing energy efficiency")) return "S. Galantino, A. Pinto, F. Esposito, A. Manzalini, & F. Risso";
  if (t.includes("transport-aware") || t.includes("block allocation")) return "A. Pinto, T. B. Hassan, F. Restuccia, & F. Esposito";
  if (t.includes("dfl-trim") || t.includes("model pruning")) return "A. Pinto, A. Masci, A. Sacco, G. Marchetto, & F. Esposito";
  if (t.includes("de-authentication")) return "A. Sangiorgi, A. Pinto, R. Tourani, & F. Esposito";
  if (t.includes("optical-wireless")) return "E. Paolini, A. Pinto, F. Esposito, & L. Valcarenghi";
  if (t.includes("maestro")) return "L. Guo, F. Fiorella, A. Pinto, A. Sacco, M. Mahmoud, & F. Esposito";
  if (t.includes("lossy wireless")) return "E. Paolini, A. Pinto, L. Valcarenghi, N. Andriolli, L. Maggiani, & F. Esposito";
  if (t.includes("trireme")) return "A. Samanta, A. Pinto, & F. Esposito";
  if (t.includes("rubix")) return "A. Samanta, A. Pinto, & F. Esposito";
  if (t.includes("flllm")) return "A. Pinto, E. Paolini, & F. Esposito";
  return "A. Pinto, G. Santaromita, C. Fiandrino, D. Giustiniano, & F. Esposito";
};
