    <!-- Client-Side Sorting Script -->
    <script>
      const list = document.getElementById('publications-list');
      const btnCitations = document.getElementById('sort-citations');
      const btnYear = document.getElementById('sort-year');

      if (list && btnCitations && btnYear) {
        const items = Array.from(list.getElementsByClassName('publication-item'));

        const sortItems = (criteria: 'citations' | 'year') => {
          items.sort((a, b) => {
            const valA = parseInt(a.getAttribute(`data-${criteria}`) || '0') || 0;
            const valB = parseInt(b.getAttribute(`data-${criteria}`) || '0') || 0;

            if (valB !== valA) {
              return valB - valA;
            }

            // Secondary sort
            const secCriteria = criteria === 'citations' ? 'year' : 'citations';
            const secA = parseInt(a.getAttribute(`data-${secCriteria}`) || '0') || 0;
            const secB = parseInt(b.getAttribute(`data-${secCriteria}`) || '0') || 0;
            return secB - secA;
          });

          // Re-append to order the DOM elements
          items.forEach(item => list.appendChild(item));
        };

        btnCitations.addEventListener('click', () => {
          btnCitations.className = "px-3 py-1 rounded text-xs font-semibold font-mono bg-cyan-600 text-white shadow-sm transition-all cursor-pointer";
          btnYear.className = "px-3 py-1 rounded text-xs font-semibold font-mono text-slate-500 hover:text-slate-200 transition-all cursor-pointer";
          sortItems('citations');
        });

        btnYear.addEventListener('click', () => {
          btnYear.className = "px-3 py-1 rounded text-xs font-semibold font-mono bg-cyan-600 text-white shadow-sm transition-all cursor-pointer";
          btnCitations.className = "px-3 py-1 rounded text-xs font-semibold font-mono text-slate-500 hover:text-slate-200 transition-all cursor-pointer";
          sortItems('year');
        });
      }

      // Mobile Menu Handler
      const btnMenu = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIconPath = document.getElementById('menu-icon-path');
      const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

      if (btnMenu && mobileMenu && menuIconPath) {
        btnMenu.addEventListener('click', () => {
          const isHidden = mobileMenu.classList.contains('hidden');
          if (isHidden) {
            mobileMenu.classList.remove('hidden');
            menuIconPath.setAttribute('d', 'M6 18 18 6M6 6l12 12');
          } else {
            mobileMenu.classList.add('hidden');
            menuIconPath.setAttribute('d', 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5');
          }
        });

        mobileNavLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            menuIconPath.setAttribute('d', 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5');
          });
        });
      }
    </script>

