    <!-- Client-Side Sorting Script -->
    <script>
      const list = document.getElementById('publications-list');
      const btnCitations = document.getElementById('sort-citations');
      const btnYear = document.getElementById('sort-year');

      if (list && btnCitations && btnYear) {
        const items = Array.from(list.getElementsByClassName('publication-item'));

        const sortItems = (criteria: 'citations' | 'year') => {
          items.sort((a, b) => {
            const valA = parseInt(a.getAttribute(`data-${criteria}`) || '0') || 0;
            const valB = parseInt(b.getAttribute(`data-${criteria}`) || '0') || 0;

            if (valB !== valA) {
              return valB - valA;
            }

            // Secondary sort
            const secCriteria = criteria === 'citations' ? 'year' : 'citations';
            const secA = parseInt(a.getAttribute(`data-${secCriteria}`) || '0') || 0;
            const secB = parseInt(b.getAttribute(`data-${secCriteria}`) || '0') || 0;
            return secB - secA;
          });

          // Re-append to order the DOM elements
          items.forEach(item => list.appendChild(item));
        };

        btnCitations.addEventListener('click', () => {
          btnCitations.className = "px-3 py-1.5 rounded-md text-xs font-semibold bg-blue-600 text-white shadow-sm transition-all cursor-pointer";
          btnYear.className = "px-3 py-1.5 rounded-md text-xs font-semibold text-slate-400 hover:text-slate-200 transition-all cursor-pointer";
          sortItems('citations');
        });

        btnYear.addEventListener('click', () => {
          btnYear.className = "px-3 py-1.5 rounded-md text-xs font-semibold bg-blue-600 text-white shadow-sm transition-all cursor-pointer";
          btnCitations.className = "px-3 py-1.5 rounded-md text-xs font-semibold text-slate-400 hover:text-slate-200 transition-all cursor-pointer";
          sortItems('year');
        });
      }
    </script>

