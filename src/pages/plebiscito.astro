---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>Plebiscito | Distributed Learning Workloads | Andrea Pinto</title>
    <meta name="description" content="Plebiscito: A Decentralized, Bandwidth-Aware Architecture for Distributed Learning Workloads" />
    <meta name="author" content="Andrea Pinto" />
    <link rel="canonical" href="https://andreapinto94.github.io/plebiscito" />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://andreapinto94.github.io/plebiscito" />
    <meta property="og:title" content="Plebiscito | Distributed Learning Workloads | Andrea Pinto" />
    <meta property="og:description" content="Plebiscito: A Decentralized, Bandwidth-Aware Architecture for Distributed Learning Workloads" />
    <meta property="og:image" content="https://andreapinto94.github.io/docs/plebi.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://andreapinto94.github.io/plebiscito" />
    <meta property="twitter:title" content="Plebiscito | Distributed Learning Workloads | Andrea Pinto" />
    <meta property="twitter:description" content="Plebiscito: A Decentralized, Bandwidth-Aware Architecture for Distributed Learning Workloads" />
    <meta property="twitter:image" content="https://andreapinto94.github.io/docs/plebi.png" />
    
    <!-- JSON-LD Structured Data / Schema Markup -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ScholarlyArticle",
        "headline": "Plebiscito: A Decentralized, Bandwidth-Aware Architecture for Distributed Learning Workloads",
        "author": [
          {"@type": "Person", "name": "Andrea Pinto"},
          {"@type": "Person", "name": "Stefano Galantino"},
          {"@type": "Person", "name": "Fulvio Risso"},
          {"@type": "Person", "name": "Flavio Esposito"}
        ],
        "publisher": {"@type": "Organization", "name": "IFIP Networking"},
        "datePublished": "2026"
      }
    </script>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
    </noscript>

    <style is:global>
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Inter', sans-serif;
      }
    </style>
  </head>

  <body class="bg-slate-900 text-slate-100 min-h-screen selection:bg-cyan-500/30 selection:text-cyan-200 relative">
    
    <main class="max-w-3xl mx-auto px-6 py-16 space-y-10">
      
      <!-- Back Button -->
      <div>
        <a href="/" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-cyan-400 transition-colors group font-mono">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          <span>Back to Portfolio</span>
        </a>
      </div>

      <!-- Header Section -->
      <div class="space-y-6">
        <a href="/docs/honorable_mention_best_paper_award_Andrea_Pinto_Stefano_Galantino_Fulvio_Risso_Flavio_Esposito.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-3 py-1 rounded border border-amber-500/20 bg-amber-500/5 hover:bg-amber-500/10 text-amber-400 text-xs font-semibold font-mono uppercase tracking-wider cursor-pointer transition-all">
          🏆 Best Paper Award (Honorable Mention)
        </a>
        
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight bg-gradient-to-r from-slate-100 via-slate-200 to-cyan-400 bg-clip-text text-transparent font-mono">
          Plebiscito: A Decentralized, Bandwidth-Aware Architecture for Distributed Learning Workloads
        </h1>
        
        <div class="flex flex-wrap items-center gap-y-2 gap-x-6 text-sm text-slate-500 font-medium font-mono">
          <div>
            <span class="text-slate-650">Authors:</span> <strong class="text-slate-200">Andrea Pinto, Stefano Galantino, Fulvio Risso, & Flavio Esposito</strong>
          </div>
          <div>
            <span class="text-slate-650">Venue:</span> <strong class="text-slate-200">IFIP Networking</strong>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-wrap items-center gap-4 py-4 border-y border-slate-800/80">
        <a href="https://opendl.ifip-tc6.org/db/conf/networking/networking2026/1571261587.pdf" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 rounded bg-cyan-600 hover:bg-cyan-500 text-white border border-cyan-500 font-mono text-sm transition-all flex items-center gap-2 cursor-pointer shadow-sm">
          <span>Read Paper PDF</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
        <a href="https://www.linkedin.com/posts/flavioesposito_nsf-activity-7465757552048369664-ff73" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 rounded border border-slate-800 bg-slate-950/50 hover:border-cyan-500/30 hover:text-cyan-400 text-slate-300 font-mono text-sm transition-all flex items-center gap-2 cursor-pointer">
          <span>LinkedIn Post</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>

      <!-- Abstract Section -->
      <div class="space-y-6">
        <h2 class="text-xl font-bold tracking-tight text-slate-100 font-mono border-l-2 border-cyan-500 pl-3">Abstract</h2>
        
        <div class="p-8 rounded border border-slate-800 bg-slate-950/40 backdrop-blur-md space-y-6 text-slate-300 leading-relaxed text-sm md:text-base">
          <p>
            As large-scale AI training increasingly relies on distributed GPU clusters, data-center network bandwidth has become a critical bottleneck. Existing systems often overlook real-time link utilization during job placement, leading to suboptimal scheduling decisions that exacerbate congestion and increase Job Completion Time (JCT).
          </p>
          <p>
            To address this gap, we introduce <strong>Plebiscito</strong>, a policy-based architecture that enables bandwidth-aware job placement in distributed AI training clusters. Using a distributed max-consensus auction protocol, nodes autonomously bid on incoming jobs based on local resource availability and network conditions.
          </p>
          <p>
            We formulate this as a network utility maximization problem and prove that our decentralized algorithm achieves a (1 - 1/e) optimality bound. Experiments on a Kubernetes-based prototype and through large-scale, trace-driven simulation show that Plebiscito reduces JCT, improves bandwidth utilization, and lowers allocation failure rates compared to bandwidth-agnostic baselines.
          </p>
          <p class="text-xs text-slate-550 font-semibold font-mono">
            <strong>Index Terms</strong>—Distributed Training, Resource Orchestration, Network Management, Data Center Systems, Bandwidth-Aware Allocation, Distributed Auctions.
          </p>
        </div>
      </div>

      <!-- Architecture Section -->
      <div class="space-y-6">
        <h2 class="text-xl font-bold tracking-tight text-slate-100 font-mono border-l-2 border-cyan-500 pl-3">System Architecture</h2>
        
        <div class="p-6 rounded border border-slate-800 bg-slate-950/40 backdrop-blur-md flex flex-col items-center space-y-4">
          <div class="w-full rounded border border-slate-800 bg-slate-950 p-4 flex items-center justify-center">
            <img 
              src="/docs/plebi.webp" 
              alt="Plebiscito System Architecture Diagram" 
              loading="lazy"
              decoding="async"
              class="max-w-full h-auto object-contain max-h-[500px]"
            />
          </div>
          <div class="text-xs text-slate-500 font-medium flex flex-wrap items-center justify-between w-full gap-2 font-mono">
            <span>A decentralized architecture for bandwidth-aware job placement using distributed auctions.</span>
            <a 
              href="/docs/plebi.png" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center gap-1 text-cyan-400 hover:text-cyan-300 transition-colors font-semibold"
            >
              <span>View Full Image</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>

    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-800/80 py-8 mt-24">
      <div class="max-w-3xl mx-auto px-6 flex items-center justify-between text-xs text-slate-500 font-semibold font-mono">
        <p>&copy; {new Date().getFullYear()} Andrea Pinto. All rights reserved.</p>
        <p>Plebiscito Paper</p>
      </div>
    </footer>

    <!-- UI Interactions -->
    <script>
      import '../scripts/ui.js';
    </script>
  </body>
</html>
