        "@context": "https://schema.org",
        "@type": "ScholarlyArticle",
        "headline": "Programmable In-Network Aggregation for Communication-Aware Federated Learning in 5G RANs",
        "author": [
          {"@type": "Person", "name": "Emilio Paolini"},
          {"@type": "Person", "name": "Andrea Pinto"},
          {"@type": "Person", "name": "Luca Valcarenghi"}
        ],
        "publisher": {"@type": "Organization", "name": "IEEE TNSM"},
        "datePublished": "2026"
      }
    </script>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />

    <style is:global>
